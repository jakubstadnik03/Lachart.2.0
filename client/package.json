{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^6.0.0",
    "@capacitor-community/bluetooth-le": "^6.1.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.3",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@capgo/capacitor-health": "^8.6.0",
    "@codetrix-studio/capacitor-google-auth": "^3.3.6",
    "@emailjs/browser": "^4.4.1",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@react-oauth/google": "^0.12.1",
    "@react-pdf/renderer": "^4.4.1",
    "@shadcn/ui": "^0.0.4",
    "@tanstack/react-table": "^8.21.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.12.2",
    "chart.js": "^4.4.7",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cra-template": "1.2.0",
    "cubic-spline": "^3.0.3",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "framer-motion": "^12.8.0",
    "html-to-image": "^1.11.13",
    "js-cookie": "^3.0.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.474.0",
    "mathjs": "^14.2.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-joyride": "^2.9.3",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.0.2",
    "react-scripts": "^5.0.1",
    "react-select": "^5.10.1",
    "recharts": "^2.15.0",
    "regression": "^2.0.1",
    "swiper": "^11.2.6"
  },
  "scripts": {
    "postinstall": "node scripts/fix-fast-equals-shim.js",
    "start": "node scripts/fix-fast-equals-shim.js && GENERATE_SOURCEMAP=false react-scripts start",
    "build": "GENERATE_SOURCEMAP=false INLINE_RUNTIME_CHUNK=false react-scripts build && npm run prerender",
    "build:no-prerender": "GENERATE_SOURCEMAP=false INLINE_RUNTIME_CHUNK=false react-scripts build",
    "prerender": "node scripts/prerender.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "cap:sync": "npm run build:no-prerender && npx cap sync && node scripts/patch-ios-health-plugin.mjs",
    "cap:sync:no-build": "npx cap sync && node scripts/patch-ios-health-plugin.mjs",
    "cap:sync:ios": "npm run build && npx cap sync ios && node scripts/patch-ios-health-plugin.mjs && cd ios/App && pod install",
    "capacitor:copy:after": "node scripts/patch-ios-health-plugin.mjs",
    "capacitor:sync:after": "node scripts/patch-ios-health-plugin.mjs",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "whats-new:videos": "node scripts/check-whats-new-videos.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended"
    ],
    "plugins": [
      "react",
      "react-hooks"
    ],
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react-hooks/exhaustive-deps": "warn",
      "react/prop-types": "off",
      "react/react-in-jsx-scope": "off",
      "react/no-unescaped-entities": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@capacitor/cli": "^6.1.2",
    "autoprefixer": "^10.4.20",
    "documentation": "^14.0.3",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.49",
    "puppeteer": "^25.1.0",
    "serve-handler": "^6.1.7",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^6.0.3"
  }
}
