require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '13.0'
use_frameworks!

# Suppress deprecation warnings from third-party pods (AppAuth, etc.)
inhibit_all_warnings!

# workaround to avoid Xcode caching of Pods that requires
# Product -> Clean Build Folder after new Cordova plugins installed
# Requires CocoaPods 1.6 or newer
install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCommunityBluetoothLe', :path => '../../node_modules/@capacitor-community/bluetooth-le'
  pod 'CapacitorApp', :path => '../../node_modules/@capacitor/app'
  pod 'CapacitorLocalNotifications', :path => '../../node_modules/@capacitor/local-notifications'
  pod 'CapacitorPushNotifications', :path => '../../node_modules/@capacitor/push-notifications'
  pod 'CapacitorSplashScreen', :path => '../../node_modules/@capacitor/splash-screen'
  pod 'CapacitorStatusBar', :path => '../../node_modules/@capacitor/status-bar'
  pod 'CodetrixStudioCapacitorGoogleAuth', :path => '../../node_modules/@codetrix-studio/capacitor-google-auth'
end

target 'App' do
  capacitor_pods
  # Add your Pods here
end

post_install do |installer|
  assertDeploymentTarget(installer)

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Suppress warnings in Pods project
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
      config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'
    end
  end

  # ── Privacy manifest injection ─────────────────────────────────────────────
  # GoogleSignIn 6.x, GTMAppAuth and GTMSessionFetcher don't ship with
  # PrivacyInfo.xcprivacy (ITMS-91061). We add a Run Script build phase to
  # each pod target that writes the manifest directly into the compiled
  # .framework bundle at build time — works in Xcode Cloud and local builds.
  privacy_xml = '<?xml version="1.0" encoding="UTF-8"?>' \
    '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" ' \
    '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">' \
    '<plist version="1.0"><dict>' \
    '<key>NSPrivacyAccessedAPITypes</key><array>' \
    '<dict><key>NSPrivacyAccessedAPIType</key>' \
    '<string>NSPrivacyAccessedAPICategoryUserDefaults</string>' \
    '<key>NSPrivacyAccessedAPITypeReasons</key>' \
    '<array><string>CA92.1</string></array></dict>' \
    '</array>' \
    '<key>NSPrivacyTracking</key><false/>' \
    '<key>NSPrivacyCollectedDataTypes</key><array/>' \
    '</dict></plist>'

  privacy_script = <<~BASH
    DEST="${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.framework/PrivacyInfo.xcprivacy"
    if [ ! -f "$DEST" ]; then
      cat > "$DEST" << 'PRIVACY_EOF'
#{privacy_xml}
PRIVACY_EOF
      echo "[privacy] Wrote PrivacyInfo.xcprivacy → ${PRODUCT_NAME}.framework"
    fi
  BASH

  %w[GoogleSignIn GTMAppAuth GTMSessionFetcher].each do |pod_name|
    target = installer.pods_project.targets.find { |t| t.name == pod_name }
    next unless target

    # Skip if we already added this phase
    next if target.shell_script_build_phases.any? { |p| p.name == 'Inject PrivacyInfo.xcprivacy' }

    phase = target.new_shell_script_build_phase('Inject PrivacyInfo.xcprivacy')
    phase.shell_script = privacy_script
    phase.show_env_vars_in_log = '0'
    puts "  [privacy] Build phase added → #{pod_name}"
  end

  installer.pods_project.save
end
