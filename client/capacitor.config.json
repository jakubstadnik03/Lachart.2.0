{
  "appId": "com.lachart.app",
  "appName": "Lachart",
  "webDir": "build",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "962857277252-hjuh1309cikav924lsp4r3et8k3sj6lk.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#ffffff",
      "androidScaleType": "CENTER_CROP"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#767EB5",
      "sound": "beep.wav"
    }
  }
}
