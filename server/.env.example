# Copy to `.env` and fill in locally. Do not commit `.env`.
# Stripe (optional — set SUBSCRIPTION_ENABLED=true when ready)
SUBSCRIPTION_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_COACH=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_ENTERPRISE=

FRONTEND_URL=http://localhost:3000
SERVER_PUBLIC_URL=

# Automated web-only re-engagement drip (app → Strava → planning)
# Auto-starts in production. Zoho-safe defaults: ~15 emails/day max.
ENABLE_APP_REENGAGEMENT_SCHEDULER=true
APP_REENGAGEMENT_DAILY_CAP=15
APP_REENGAGEMENT_EMAILS_PER_TICK=3
APP_REENGAGEMENT_EMAIL_GAP_MS=120000
APP_REENGAGEMENT_STEP_GAP_DAYS=7
APP_REENGAGEMENT_MIN_GAP_DAYS=6

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Strava auto-sync cadence: server/config/stravaAutoSyncConfig.js (not env)
MONGODB_URI=
